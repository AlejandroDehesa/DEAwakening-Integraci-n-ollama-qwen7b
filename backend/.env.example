NODE_ENV=development
PORT=5000
ADMIN_KEY=replace-with-a-strong-random-admin-key
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=
DISABLE_HTTP_LOGS=false
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=15000
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=DEAwakening
ASSISTANT_DOCUMENTS_DIR=./knowledge/documents
ASSISTANT_FORCE_DOCUMENT_ERROR=false
ASSISTANT_TRACKING_ENABLED=true
ASSISTANT_FORCE_TRACKING_ERROR=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-app-password
CONTACT_FROM=your-smtp-user@gmail.com
CONTACT_RECEIVER=resosense@gmail.com
CONTACT_EMAIL_REQUIRED=false
