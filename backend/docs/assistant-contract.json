{
  "assistantChat": {
    "endpoint": {
      "method": "POST",
      "path": "/api/assistant/chat"
    },
    "request": {
      "message": "string (required, max 4000)",
      "language": "en|es|de (optional, default en)",
      "sessionId": "string (optional, max 120)",
      "pageContext": "home|events|event-detail|about|book|contact|host-event (optional)",
      "pageSlug": "string (optional, required when pageContext=event-detail, slug format)"
    },
    "response": {
      "success": true,
      "data": {
        "contractVersion": "assistant.v2",
        "answer": "string",
        "language": "en|es|de",
        "pageIntent": "general_info|event_discovery|book_interest|contact_interest|about_david|guidance",
        "confidence": 0.84,
        "suggestedActions": [
          {
            "type": "route|event|contact|book|external",
            "label": "string",
            "target": "string"
          }
        ],
        "relatedLinks": [
          {
            "label": "string",
            "target": "string"
          }
        ],
        "recommendedEventSlug": "string|null",
        "knowledgeStatus": {
          "site": "ok",
          "documents": "ok|empty|unavailable"
        },
        "interactionId": "number|null",
        "intent": "legacy alias of pageIntent"
      },
      "error": null
    },
    "canonicalFields": [
      "contractVersion",
      "answer",
      "language",
      "pageIntent",
      "confidence",
      "suggestedActions",
      "relatedLinks",
      "recommendedEventSlug",
      "knowledgeStatus",
      "interactionId"
    ],
    "legacyCompatibility": [
      "intent (alias of pageIntent)"
    ]
  },
  "assistantClickTracking": {
    "endpoint": {
      "method": "POST",
      "path": "/api/assistant/track-click"
    },
    "request": {
      "source": "hero|widget (required)",
      "clickType": "quick-action|suggested-action|related-link|recommended-event (required)",
      "label": "string (required)",
      "target": "string (required)",
      "targetRules": {
        "quick-action": "qa:<id>",
        "otherClickTypes": "internal route (/...) or external URL (http/https)"
      },
      "actionType": "string (optional)",
      "interactionId": "number (optional)",
      "sessionId": "string (optional)",
      "language": "en|es|de (optional)",
      "pageContext": "home|events|event-detail|about|book|contact|host-event (optional)",
      "pageSlug": "string (optional)",
      "pageIntent": "string (optional)",
      "recommendedEventSlug": "string (optional)"
    },
    "response": {
      "success": true,
      "data": {
        "tracked": "boolean",
        "clickId": "number|null"
      },
      "error": null
    }
  },
  "adminInsights": {
    "endpoint": {
      "method": "GET",
      "path": "/api/admin/assistant/insights?days=30&limit=200&includeRecent=true",
      "auth": "x-admin-key header required"
    },
    "response": {
      "success": true,
      "data": {
        "contractVersion": "assistant-insights.v2",
        "periodDays": "number",
        "sampleSize": {
          "interactions": "number",
          "clicks": "number"
        },
        "overview": {
          "totalInteractions": "number",
          "totalClicks": "number",
          "clicksPerInteraction": "number"
        },
        "usage": {
          "byIntent": "array",
          "byLanguage": "array",
          "byPageContext": "array",
          "byKnowledgeStatus": {
            "documents": "array",
            "site": "array"
          },
          "pagePerformance": "array"
        },
        "actions": {
          "suggested": {
            "topTargets": "array",
            "byType": "array",
            "relatedLinksTopTargets": "array"
          },
          "clicks": {
            "topTargets": "array",
            "byType": "array",
            "bySource": "array"
          }
        },
        "conversion": {
          "suggested": "object",
          "clicked": "object",
          "rates": "object"
        },
        "recommendations": {
          "totalRecommended": "number",
          "recommendedEventClicks": "number",
          "recommendationClickRate": "number",
          "topEvents": "array"
        },
        "interactions": "legacy shape kept",
        "suggestions": "legacy shape kept",
        "clicks": "legacy shape kept",
        "recent": "optional when includeRecent=true"
      },
      "error": null
    }
  },
  "frontendResponsibility": {
    "must": [
      "send language + pageContext + pageSlug",
      "render answer, intent, confidence, actions, links and recommendation",
      "track click actions and quick actions with non-blocking behavior",
      "sanitize malformed arrays defensively"
    ],
    "mustNot": [
      "duplicate business recommendation logic from backend",
      "convert frontend into an insights aggregation layer"
    ]
  }
}
